<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI_AITM — Student Signup</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="preload" as="image" href="aitm.png">
  <style>
    :root {
      --bg-primary: #0f0f1a;
      --bg-secondary: #1a1a2e;
      --accent: #6c5ce7;
      --accent-glow: rgba(108, 92, 231, 0.4);
      --text: #f8f9fa;
      --text-muted: #adb5bd;
      --danger: #ff6b6b;
      --success: #55efc4;
      --card-bg: rgba(30, 30, 50, 0.7);
      --border: rgba(255, 255, 255, 0.1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: linear-gradient(135deg, var(--bg-primary), #16213e);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text);
      padding: 20px;
    }

    .signup-container {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 20px;
      padding: 40px;
      width: 100%;
      max-width: 450px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3),
                  0 0 20px var(--accent-glow);
      border: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .signup-container::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, transparent 20%, var(--bg-secondary) 200%);
      z-index: -1;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--text-muted);
      text-decoration: none;
      margin-bottom: 20px;
      transition: color 0.3s;
      font-size: 0.9rem;
    }

    .back-link:hover {
      color: var(--accent);
    }

    .brand {
      text-align: center;
      margin-bottom: 30px;
    }

    .brand h1 {
      font-size: 2rem;
      font-weight: 800;
      background: linear-gradient(90deg, #55efc4, #74b9ff);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-icon {
     height: 26.4px;
     width: 26.4px;
     object-fit: cover;
     border-radius: 50%;
     margin-right: 12px;
     border: 2px solid rgba(255, 255, 255, 0.1);
     box-shadow: 0 0 8px rgba(108, 92, 231, 0.3);
     transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .logo-icon:hover {
      transform: scale(1.05);
      box-shadow: 0 0 12px rgba(108, 92, 231, 0.5);
    }

    .brand p {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-top: 8px;
    }

    .form-group {
      margin: 20px 0;
      text-align: left;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text);
      letter-spacing: 0.5px;
    }

    input {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      font-size: 1rem;
      color: var(--text);
      transition: all 0.3s ease;
      outline: none;
    }

    input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
      background: rgba(108, 92, 231, 0.05);
    }

    .btn {
      display: block;
      width: 100%;
      padding: 16px;
      margin: 22px 0;
      border: none;
      border-radius: 14px;
      font-size: 1.05rem;
      font-weight: 600;
      cursor: pointer;
      background: linear-gradient(90deg, var(--accent), #55efc4);
      color: white;
      transition: all 0.3s ease;
      letter-spacing: 0.5px;
      box-shadow: 0 4px 20px rgba(108, 92, 231, 0.3);
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(108, 92, 231, 0.4);
    }

    .btn:active {
      transform: scale(0.98);
    }

    .link-btn {
      background: none;
      color: var(--accent);
      font-size: 0.95rem;
      text-decoration: none;
      padding: 6px 0;
      border: none;
      cursor: pointer;
      display: inline;
      font-weight: 500;
    }

    .link-btn:hover {
      text-decoration: underline;
    }

    .message {
      margin: 20px 0;
      padding: 14px;
      border-radius: 12px;
      font-weight: 500;
      text-align: center;
      display: none;
      animation: fadeIn 0.4s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .success {
      background: rgba(85, 239, 196, 0.15);
      color: #2ecc71;
      border: 1px solid rgba(85, 239, 196, 0.3);
    }

    .error {
      background: rgba(255, 107, 107, 0.15);
      color: #ff6b6b;
      border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .info {
      background: rgba(108, 92, 231, 0.15);
      color: #a29bfe;
      border: 1px solid rgba(108, 92, 231, 0.3);
    }

    #verificationPending {
      display: none;
      text-align: center;
      padding: 30px 0;
    }

    #verificationPending h3 {
      font-size: 1.5rem;
      margin-bottom: 15px;
      color: var(--success);
    }

    #verificationPending p {
      margin: 10px 0;
      color: var(--text-muted);
    }

    .resend {
      background: none;
      border: 1px solid var(--accent);
      color: var(--accent);
      padding: 10px 20px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 500;
      margin: 15px 0;
      transition: all 0.3s;
    }

    .resend:hover {
      background: var(--accent);
      color: white;
    }

    @media (max-width: 480px) {
      .signup-container {
        padding: 30px 20px;
        margin: 10px;
      }
      .brand h1 {
        font-size: 1.7rem;
      }
    }
  </style>
</head>
<body>
  <div class="signup-container">
    <a href="index.html" class="back-link">
      <i class="fas fa-arrow-left"></i> Back to Login
    </a>
    
    <div class="brand">
      <h1>
        <img src="aitm.png" alt="AITM Logo" class="logo-icon" />
        Student Signup
      </h1>
      <p>Create your AI_AITM account</p>
    </div>

    <div class="message" id="message"></div>

    <!-- Signup Form -->
    <div id="signupForm">
        showMessage("📧 Verification email sent! Please verify to activate your account.", "success");

      } catch (error) {
        showMessage("Signup failed: " + error.message, "error");
      }
    }

    // Go to Login
    function goToLogin() {
      window.location.href = 'index.html';
    }

    // Optional: If user is already logged in & verified, redirect
    auth.onAuthStateChanged(user => {
      if (user && user.emailVerified) {
        window.location.href = 'index.html';
      }
    });
  </script>
</body>
</html>